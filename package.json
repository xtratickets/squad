{
  "name": "squad-new",
  "version": "1.0.0",
  "description": "",
  "main": "dist/main.js",
  "directories": {
    "test": "tests",
    "main": "dist/main.js"
  },
  "scripts": {
    "build": "npm run build:frontend && tsc",
    "start": "node dist/server.js",
    "start:prod": "NODE_ENV=production node dist/server.js",
    "start:all": "concurrently \"npm run start:prod\" \"npm run serve:frontend\"",
    "serve:frontend": "serve -s frontend/dist -l 5173",
    "dev:backend": "nodemon --watch src --ext ts --exec ts-node src/server.ts",
    "dev:frontend": "cd frontend && npm run dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "electron": "electron .",
    "dev:electron": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" \"wait-on http://localhost:5173 && tsc && electron .\"",
    "build:frontend": "cd frontend && npm run build",
    "ci:frontend": "cd frontend && npm ci",
    "dist": "npm run build && electron-builder",
    "test": "jest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "@types/multer": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "minio": "^8.0.6",
    "multer": "^2.0.2",
    "nodemon": "^3.1.13",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.19.2",
    "serve": "^14.2.5",
    "socket.io": "^4.8.3",
    "ts-node": "^10.9.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.0",
    "@types/socket.io": "^3.0.1",
    "concurrently": "^9.2.1",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "jest": "^29.7.0",
    "jest-mock-extended": "^4.0.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3",
    "ux": "^0.3.0",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.squad.pos",
    "productName": "SQUAD POS",
    "directories": {
      "output": "dist-app"
    },
    "files": [
      "dist/**/*",
      "public/**/*",
      "prisma/**/*",
      "frontend/dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "extraResources": [
      "prisma/schema.prisma",
      "prisma/dev.db"
    ]
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}